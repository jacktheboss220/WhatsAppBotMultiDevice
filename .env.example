# WhatsApp Bot Configuration
# Copy this file to .env and fill in your actual values

# Bot Configuration
PREFIX=-
MY_NUMBER=your_whatsapp_numbers_without_plus
MODERATORS=number1,number2,number3

# Database
MONGODB_KEY=your_mongodb_connection_string

# Server Configuration
PORT=8000
NODE_ENV=development

# Google APIs
GOOGLE_API_KEY=your_google_api_key
SEARCH_ENGINE_KEY=your_google_search_engine_key

# Third Party APIs
GENIUS_ACCESS_SECRET=your_genius_api_secret
REMOVE_BG_KEY=your_remove_bg_api_key
TRUECALLER_ID=your_truecaller_id
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# FFmpeg Configuration (Optional)
# Set custom FFmpeg path if ffmpeg-static doesn't work
# Example: FFMPEG_PATH=C:/ffmpeg/bin/ffmpeg.exe
FFMPEG_PATH=

# Telegram Logger
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Admin Web UI
ADMIN_PASSWORD=
SESSION_SECRET=

#Google OAuth Credentials (Optional, for Admin Dashboard Authentication)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_ALLOWED_EMAILS=your_allowed_email_addresses

# YouTube Download (yt-dlp)
# Path to the yt-dlp binary. Set on the server (Docker installs it at
# /usr/local/bin/yt-dlp). Leave blank locally to use the bundled binary.
YTDLP_PATH=
# Path to a Netscape-format cookies.txt exported from a logged-in browser.
# Set this on the server to fix "Sign in to confirm" / age-restricted errors.
YTDLP_COOKIES=

# Redis
# Set USE_REDIS=false to force in-memory cache (no Redis needed)
USE_REDIS=false
# Option A — URL (recommended for Upstash, TLS auto-detected from rediss://)
REDIS_URL=
# Option B — individual fields (redis.io or self-hosted)
REDIS_HOST=
REDIS_PORT=
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_TLS=false
